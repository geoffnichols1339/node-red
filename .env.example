# =============================================================================
# node-red Home Automation — Environment Variables
# Copy this file to .env on avalon2 and fill in all values.
# .env is gitignored — never commit it.
# =============================================================================

# -----------------------------------------------------------------------------
# Timezone
# -----------------------------------------------------------------------------
# IANA timezone string for the Node-RED container.
TZ=Europe/Helsinki

# -----------------------------------------------------------------------------
# Node-RED security
# -----------------------------------------------------------------------------
# Random secret used to encrypt flow credentials (flows_cred.json).
# Generate once with: openssl rand -hex 32
# WARNING: Never change this after flows are deployed — it will break credential decryption.
NODE_RED_CREDENTIAL_SECRET=

# Node-RED editor admin username.
NODE_RED_ADMIN_USERNAME=admin

# Bcrypt hash of the editor admin password.
# Generate with:
#   docker run --rm nodered/node-red node -e \
#     "const b=require('bcryptjs'); b.hash('YOUR_PASSWORD',8,(e,h)=>console.log(h))"
# Paste the resulting hash here (starts with $2b$).
NODE_RED_ADMIN_PASSWORD_HASH=

# -----------------------------------------------------------------------------
# MQTT broker
# -----------------------------------------------------------------------------
# Hostname or IP of the existing Mosquitto broker on your LAN.
MQTT_HOST=192.168.7.14

# MQTT broker port (default 1883; use 8883 for TLS).
MQTT_PORT=1883

# MQTT broker credentials (leave blank if broker allows anonymous connections).
MQTT_USERNAME=
MQTT_PASSWORD=

# -----------------------------------------------------------------------------
# Zigbee2MQTT
# -----------------------------------------------------------------------------
# Base topic prefix configured in your Zigbee2MQTT instance.
# Default is "zigbee2mqtt" — change only if you customized it.
Z2M_TOPIC_PREFIX=zigbee2mqtt
